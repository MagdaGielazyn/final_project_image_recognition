r learningu","metadata":{}},{"cell_type":"code","source":"# Budujemy model z EfficcientNetB0\n\ndef effNet_model(num_classes=4, input_shape=(150, 150, 3)):\n\n  effNet_model = tf.keras.applications.EfficientNetB0(\n      weights=\"imagenet\", # ładujemy pretrenowane wagi na imagenet\n      include_top=False, # usuwamy orgnialny klasyfikator dla 1000 klas\n      input_shape=input_shape\n  )\n\n  effNet_model.trainable = False # zamrażamy bazowe wagi\n\n# Dodajemy nasz klasyfikator\n  inputs = tf.keras.Input(shape=input_shape)\n  x = effNet_model(inputs, training=False)\n  x = layers.GlobalAveragePooling2D()(x)\n  x = layers.Dropout(0.3)(x)\n  outputs = layers.Dense(num_classes, activation=\"softmax\")(x)\n\n  return tf.keras.Model(inputs, outputs)\n\nmodel_effNet = effNet_model()\nmodel_effNet.summary()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-09T11:57:14.817903Z","iopub.execute_input":"2026-03-09T11:57:14.818494Z","iopub.status.idle":"2026-03-09T11:57:16.578082Z","shell.execute_reply.started":"2026-03-09T11:57:14.818465Z","shell.execute_reply":"2026-03-09T11:57:16.577402Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# kompilacja uczenia\n\nmodel_effNet.compile(\n    optimizer=tf.optimizers.Adam(learning_rate=0.001),\n    loss=\"categorical_crossentropy\",\n    metrics=[\"accuracy\"]\n)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-09T11:58:07.620012Z","iopub.execute_input":"2026-03-09T11:58:07.620668Z","iopub.status.idle":"2026-03-09T11:58:07.635254Z","shell.execute_reply.started":"2026-03-09T11:58:07.620636Z","shell.execute_reply":"2026-03-09T11:58:07.634477Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# Trening\n\nhistory_effNet = model_effNet.fit(\n    batched_train_ds_effNet,\n    validation_data=batched_val_ds_effNet,\n    epochs=num_of_epochs,\n    callbacks=callbacks\n)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-09T11:58:07.636689